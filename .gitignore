# Generated Vim spell files
*.spl
# Spell directory (moved to private dotfiles)
src/neovim/spell/
# Generated Neovim colorscheme files (live in $XDG_CACHE_HOME/nvim/colors/).
# Safety net in case an old generator writes back here.
src/neovim/colors/

# Neovim plugin lock file at repo root (not used; lazy.nvim's actual
# lock file lives at src/neovim/lazy-lock.json which IS tracked).
src/lazy-lock.json

# Re-include the actual lazy.nvim lock file. It is tracked so that
# CI cache keys can hash it and so plugin versions are reproducible
# across machines (per lazy.nvim's documentation).
!src/neovim/lazy-lock.json

# Runtime generated files
.netrwhist
Session.vim

# Claude Code configuration
.claude/
src/.claude/
**/settings.local.json

# Debug and log files
vimlog.txt
debug-neovim-config.sh
*.log
test/logs/
test/reports/

# Zsh completion cache
.zcompdump
.zcompdump-*
src/zsh/.zcompdump

# Backup and temporary files
*.backup
*.orig
*.swp
*~
.DS_Store

# WezTerm debug files and generated theme
wezterm_*.txt
src/wezterm/theme.lua
src/wezterm/current-theme

# Kitty generated theme
src/kitty/theme.conf

# Private dotfiles (now untracked)
.dotfiles.private/
template/public/

# Debug logs
log.txt
log_2.txt
test/test-results.xml

# Re-include lib/ directories — the user's global ~/.gitignore excludes
# lib/ (Python venv directories), which would otherwise hide our shell
# library, test framework, and lib unit tests.
!src/lib/
!src/lib/**
!test/lib/
!test/lib/**
!test/unit/lib/
!test/unit/lib/**
