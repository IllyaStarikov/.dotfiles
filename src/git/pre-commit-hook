#!/usr/bin/env zsh
# Pre-commit hook for secret scanning with gitleaks
#
# DESCRIPTION:
#   Scans staged files for potential secrets and sensitive information
#   before allowing commits. Uses gitleaks for detection.
#
# REQUIREMENTS:
#   gitleaks - Install with: brew install gitleaks
#
# CONFIGURATION:
#   Uses .gitleaks.toml in repo root or Gitleaks default configuration
#   See: https://github.com/gitleaks/gitleaks
#
# BYPASS:
#   git commit --no-verify (use only for false positives)

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Check if gitleaks is installed. Fail closed: a missing scanner means
# secrets ship undetected, which defeats the purpose of the hook. To
# bypass intentionally (e.g., committing on a fresh machine before brew
# install runs), use `git commit --no-verify`.
if ! command -v gitleaks &> /dev/null; then
    echo -e "${RED}✗ gitleaks is not installed${NC}"
    echo "Install with: brew install gitleaks"
    echo "Then re-run the commit, or bypass once with: git commit --no-verify"
    exit 1
fi

# Find gitleaks config (check local repo only)
GITLEAKS_CONFIG=""
if [[ -f ".gitleaks.toml" ]]; then
    GITLEAKS_CONFIG=".gitleaks.toml"
fi

# Run gitleaks on staged files
echo "🔍 Scanning for secrets..."

if [[ -n "$GITLEAKS_CONFIG" ]]; then
    gitleaks protect --staged --config="$GITLEAKS_CONFIG" --verbose --no-banner
else
    gitleaks protect --staged --verbose --no-banner
fi

RESULT=$?

if [[ $RESULT -ne 0 ]]; then
    echo -e "${RED}❌ Potential secrets detected!${NC}"
    echo "Please remove sensitive information before committing."
    echo ""
    echo "If this is a false positive, you can:"
    echo "1. Update the gitleaks.toml configuration"
    echo "2. Use 'git commit --no-verify' to skip this check (NOT RECOMMENDED)"
    exit 1
else
    echo -e "${GREEN}✅ No secrets detected${NC}"
fi