#!/usr/bin/env bash
# censor-env — Print environment variables with secrets censored
# Safe for pasting into chat, issues, or bug reports

set -euo pipefail

usage() {
  echo "Usage: censor-env [--copy]"
  echo "  --copy  Also copy output to clipboard (macOS)"
  exit 0
}

censor() {
  sed -E \
    -e 's/(API[_-]?KEY|TOKEN|SECRET|PASSWORD|PASSWD|PWD|CREDENTIALS|AUTH)=.*/\1=<REDACTED>/i' \
    -e 's/(.*KEY.*)=.*/\1=<REDACTED>/i' \
    -e 's/(.*SECRET.*)=.*/\1=<REDACTED>/i' \
    -e 's/(.*TOKEN.*)=.*/\1=<REDACTED>/i' \
    -e 's/(.*PASSWORD.*)=.*/\1=<REDACTED>/i' \
    -e 's/=[A-Za-z0-9+\/._-]{40,}/=<REDACTED_TOKEN>/g' \
    -e 's/[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}/<IP>/g' \
    -e 's/([A-Za-z0-9._%+-]+)@([A-Za-z0-9.-]+\.[A-Za-z]{2,})/<EMAIL>/g' \
    -e "s|/Users/[^/: ]+|/Users/<USER>|g" \
    -e "s|/home/[^/: ]+|/home/<USER>|g"
}

copy=false
[[ "${1:-}" == "--copy" ]] && copy=true
[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage

output=$(env | sort | censor)

echo "$output"

if $copy && command -v pbcopy &>/dev/null; then
  echo "$output" | pbcopy
  echo -e "\n(Copied to clipboard)" >&2
fi
