#!/usr/bin/env zsh
# Start a tmux session named after the git repo or current directory
# Usage: tmux-auto [path]

if (( $# > 1 )); then
  print -u2 "tmux-auto: too many arguments"
  exit 2
fi

if (( $# == 1 )); then
  cd -- "$1" || exit 1
fi

# Get session name
if git rev-parse --is-inside-work-tree &>/dev/null; then
  name=$(basename "$(git rev-parse --show-toplevel)")
else
  name=$(basename "$PWD")
fi

# Sanitize for tmux (colons are special in session:window.pane syntax)
name=${name//:/-}

# Strip leading dots and replace remaining dots with underscores
name=${name#.}
name=${name//./_}

# Check if session already exists
if tmux has-session -t "$name" 2>/dev/null; then
  tmux attach -t "$name"
else
  tmux new-session -s "$name"
fi
